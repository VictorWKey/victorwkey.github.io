---
import { useTranslations } from '../i18n/index.js'

const { lang = 'en' } = Astro.props;
const t = useTranslations(lang);

const EDU_IMAGES: Record<number, string> = {
  0: '/ug-logo.png',
  1: '/platzi-logo.jpg'
};
---

<section id="education" class="w-full flex flex-col items-center py-20 px-6 scroll-mt-16 bg-gray-50 dark:bg-gray-900">
  <div class="w-full max-w-4xl">
    <h2 class="section-heading text-3xl sm:text-4xl text-center mb-3 text-gray-900 dark:text-white">{t.education.sectionTitle}</h2>
    <p class="section-subheading text-center mb-12 text-gray-600 dark:text-gray-300">
      {t.education.sectionSubtitle}
    </p>

    <div class="space-y-6">
      {t.education.items.map((item: any, index: number) => (
        <div class="card p-6">
          <div class="flex flex-col sm:flex-row gap-4">
            <!-- Institution logo -->
            <div class="flex-shrink-0">
              <img
                src={EDU_IMAGES[index]}
                alt={item.institution}
                class="w-14 h-14 rounded-lg object-contain border border-gray-200 dark:border-gray-700 bg-white p-1"
              />
            </div>

            <div class="flex-1 min-w-0">
              <!-- Institution & Degree -->
              <h3 class="text-lg font-semibold text-gray-900 dark:text-white">{item.institution}</h3>
              <p class="text-sm text-gray-700 dark:text-gray-300 font-medium">{item.degree}</p>
              
              {item.campus && (
                <p class="text-sm text-gray-500 dark:text-gray-400 mt-0.5">{item.campus}</p>
              )}

              <!-- Date & Location -->
              <div class="flex flex-col sm:flex-row sm:items-center gap-1 sm:gap-3 mt-1">
                <span class="text-sm text-gray-500 dark:text-gray-400">
                  {item.startDate} – {item.endDate}
                </span>
                {item.location && (
                  <>
                    <span class="hidden sm:inline text-gray-300 dark:text-gray-600">·</span>
                    <span class="text-sm text-gray-500 dark:text-gray-400">{item.location}</span>
                  </>
                )}
              </div>

              <!-- Description -->
              <p class="mt-4 text-sm text-gray-600 dark:text-gray-400 leading-relaxed">
                {item.description}
              </p>

              <!-- Areas of study -->
              {item.areas && item.areas.length > 0 && (
                <ul class="mt-3 space-y-1.5">
                  {item.areas.map((area: string) => (
                    <li class="flex gap-2 text-sm text-gray-600 dark:text-gray-400 leading-snug">
                      <span class="text-primary flex-shrink-0 leading-snug">▹</span>
                      <span>{area}</span>
                    </li>
                  ))}
                </ul>
              )}
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

---
import { useTranslations } from '../i18n/index.js'

const { lang = 'en' } = Astro.props;
const t = useTranslations(lang);

const EXPERIENCE_IMAGES: Record<number, string> = {
  0: '/vortice-coaching-200x200.jpg'
};
---

<section id="experience" class="w-full flex flex-col items-center py-12 sm:py-20 px-4 sm:px-6 scroll-mt-16 bg-gray-50 dark:bg-gray-900">
  <div class="w-full max-w-4xl">
    <h2 class="section-heading text-3xl sm:text-4xl text-center mb-3 text-gray-900 dark:text-white">{t.experience.sectionTitle}</h2>
    <p class="section-subheading text-center mb-8 sm:mb-12 text-gray-600 dark:text-gray-300">
      {t.experience.sectionSubtitle}
    </p>

    <div class="relative">
      <!-- Timeline line -->
      <div class="absolute left-4 sm:left-8 top-0 bottom-0 w-px bg-gray-200 dark:bg-gray-700"></div>

      {t.experience.items.map((item: any, index: number) => (
        <div class="relative pl-10 sm:pl-20 pb-6 sm:pb-12 last:pb-0">
          <!-- Timeline dot -->
          <div class="absolute left-2.5 sm:left-6 top-1 w-3 h-3 sm:w-4 sm:h-4 rounded-full border-2 border-primary bg-white dark:bg-gray-900 z-10"></div>
          
          <a href="https://www.vortice.com.mx/" target="_blank" rel="noopener" class="card p-4 sm:p-6 inline-block w-full hover:shadow-lg hover:border-primary/30 transition-all duration-200 cursor-pointer">
            <div class="flex flex-col sm:flex-row gap-4">
              <!-- Company logo -->
              <div class="flex-shrink-0">
                <img
                  src={EXPERIENCE_IMAGES[index]}
                  alt={item.company}
                  class="w-14 h-14 rounded-lg object-cover border border-gray-200 dark:border-gray-700"
                />
              </div>

              <div class="flex-1 min-w-0">
                <!-- Role & Company -->
                <h3 class="text-lg font-semibold text-gray-900 dark:text-white">{item.role}</h3>
                <p class="text-sm text-gray-700 dark:text-gray-300 font-medium">
                  <span class="text-primary/90">{item.company}</span> · {item.type}
                </p>
                
                <!-- Date & Location -->
                <div class="flex flex-col sm:flex-row sm:items-center gap-1 sm:gap-3 mt-1">
                  <span class="text-sm text-gray-500 dark:text-gray-400">
                    {item.startDate} – <span class="text-primary font-medium">{t.experience.present}</span>
                  </span>
                  <span class="hidden sm:inline text-gray-300 dark:text-gray-600">·</span>
                  <span class="text-sm text-gray-500 dark:text-gray-400">{item.location}</span>
                </div>

                <!-- Description -->
                <p class="mt-4 text-sm text-gray-600 dark:text-gray-400 leading-relaxed">
                  {item.description}
                </p>

                <!-- Highlights -->
                {item.highlights && item.highlights.length > 0 && (
                  <ul class="mt-3 space-y-1.5">
                    {item.highlights.map((highlight: string) => (
                      <li class="flex gap-2 text-sm text-gray-600 dark:text-gray-400 leading-snug">
                        <span class="text-primary flex-shrink-0 leading-snug">▹</span>
                        <span>{highlight}</span>
                      </li>
                    ))}
                  </ul>
                )}
              </div>
            </div>
          </a>
        </div>
      ))}
    </div>
  </div>
</section>
